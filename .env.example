# PostgreSQL Database (Production)
DATABASE_URL=postgresql://username:password@host:5432/database

# JWT (Generate a strong random secret for production)
JWT_SECRET=your-very-long-random-jwt-secret-here

# Server
PORT=4003
NODE_ENV=production

# Reverse proxy (production)
# If deployed behind nginx/LB, Express may need trust proxy enabled for correct IP + rate limiting.
# TRUST_PROXY=1

# Frontend base URL (Production domain)
FRONTEND_URL=https://translator.studiodtw.net
VITE_API_BASE_URL=https://translator.studiodtw.net/api

# Optional: Grok (xAI) Translation, STT, TTS and Voice (realtime)
# GROK_API_KEY=your_grok_api_key
# GROK_API_BASE_URL=https://api.x.ai/v1
# GROK_TRANSLATE_MODEL=grok-4-1-fast-reasoning

# Voice realtime uses the same key. Ephemeral tokens are issued server-side for Practice mode.